{
    "expo": {
        "name": "AI Tutor",
        "slug": "ai-tutor",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "light",
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
        },
        "assetBundlePatterns": [
            "**/*"
        ],
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.aiedtech.aitutor",
            "infoPlist": {
                "NSMicrophoneUsageDescription": "AI Tutor uses your microphone so you can talk with your tutor in Voice mode."
            }
        },
        "android": {
            "package": "com.aiedtech.aitutor",
            "versionCode": 1,
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#ffffff"
            },
            "permissions": [
                "android.permission.RECORD_AUDIO",
                "android.permission.MODIFY_AUDIO_SETTINGS"
            ]
        },
        "web": {
            "favicon": "./assets/favicon.png"
        },
        "scheme": "ai-tutor",
        "plugins": [
            "expo-router",
            [
                "expo-av",
                {
                    "microphonePermission": "AI Tutor uses your microphone so you can talk with your tutor in Voice mode."
                }
            ]
        ],
        "extra": {
            "apiBaseUrl": "https://api.your-domain.com/api/v1",
            "eas": {
                "projectId": "YOUR_EAS_PROJECT_ID"
            }
        }
    }
}
